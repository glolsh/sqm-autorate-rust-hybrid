config sqm-autorate 'main'
    option enabled '0'
    option interface 'eth1'
    # Base bandwidth in kbits. 0 = Unlimited.
    option download_base_kbits '750000'
    option upload_base_kbits '750000'
    # Max bandwidth in kbits (hardware ceiling limit). 0 = Unlimited.
    # option download_max_kbits '0'
    # option upload_max_kbits '0'
    # Min bandwidth during congestion (absolute value in kbits).
    option download_min_kbits '375000'
    option upload_min_kbits '375000'
    # Latency threshold (ms). If exceeded, speed drops.
    option download_delay_ms '20.0'
    option upload_delay_ms '20.0'
    # List of IPs to ping (space separated).
    option reflectors '1.1.1.1 8.8.8.8'
    option log_level 'info'
    # AIMD Rate control settings
    option increase_step_kbits '5000.0'
    option decrease_multiplier '0.85'
    option cooldown_secs '10.0'
